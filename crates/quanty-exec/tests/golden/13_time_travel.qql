# AS OF reads against commit ids, including schema history
#
# no branch or switch here, so commit ids are exactly the data writes:
# table = 1, first put = 2, second put = 3, set = 4.

> table t { id: int @key, v: int = 0 }
ok

> put t { id: 1, v: 100 }
put 1

> put t { id: 2, v: 200 }
put 1

> set t where id = 1 { v = 999 }
set 1

# current state
> get t
1|999
2|200

# just after the first insert
> get t as of 2
1|100

# after both inserts, before the update
> get t as of 3
1|100
2|200

# a projection and a filter still apply to a historical read
> get t { v } as of 3 where id = 2
200

# at commit 1 the table exists but holds no rows
> get t as of 1
